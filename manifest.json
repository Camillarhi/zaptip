{
  "manifest_version": 3,
  "name": "Zaptip",
  "version": "1.0.0",
  "description": "Tip GitHub profiles with Bitcoin Lightning payments. Detects a Lightning address in a profile bio and adds a Zap button.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Zaptip",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["webln-bridge.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://github.com/*"],
      "js": ["qrcode.min.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["qrcode.min.js"],
      "matches": ["https://github.com/*"]
    }
  ],
  "host_permissions": [
    "https://github.com/*",
    "https://*/*"
  ]
}
